# Normalize all text files to LF in the repo. Windows checkouts may still see
# CRLF locally; what matters is what's stored in the index and on CI.
* text=auto eol=lf

# Lockfiles and JSON benefit from explicit LF.
*.json text eol=lf
*.md text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.html text eol=lf
*.css text eol=lf
*.yml text eol=lf

# Binary
*.png binary
*.jpg binary
*.zip binary

{
  "name": "skinsight",
  "displayName": "Skinsight",
  "version": "0.1.0",
  "private": true,
  "description": "CS2 skin arbitrage + rare sticker scanner for SkinsMonkey, CSFloat, PirateSwap and CS.Money.",
  "author": "Sganzerla",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "scripts": {
    "predev": "node scripts/build-rare-data.mjs && node scripts/build-icons.mjs",
    "prebuild": "node scripts/build-rare-data.mjs && node scripts/build-icons.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack": "npm run build && node scripts/pack-zip.mjs"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.0.0-beta.25",
    "@eslint/js": "^9.5.0",
    "@types/chrome": "^0.0.268",
    "eslint": "^9.5.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.2",
    "sharp": "^0.33.5",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  }
}
